# העתיקו לקובץ `.env.docker` (לא בקומיט; כבר מכוסה על ידי `.env*` ב־gitignore).
# הרצה מקומית:
#   docker compose --env-file .env.docker up --build
#
# בלי קובץ env: ערכי ברירת־מחדל ב־docker-compose (Clerk placeholder — לא מתאים לפרודקשן).

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# MongoDB מתוך הקונטיינר (שם שירות ברשת docker: mongo)
MONGODB_URI=mongodb://mongo:27017/parent-guide

# Clerk — חובה לריצה
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# אופציונלי
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# מייל ניוזלטר (אופציונלי)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=
