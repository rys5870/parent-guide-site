# קובץ זה יושב בתיקיית הפריסה על השרת יחד עם `docker-compose.prod.yml`.
# APP_IMAGE — אופציונלי: אחרי בנייה מקומית עם `docker build -t parent-guide:latest` אפשר להשמיט (ברירת מחדל ב־compose).
# למשיכת תמונה מהרישום (GHCR וכו'): APP_IMAGE=ghcr.io/org/repo:latest
#
# בנייה בשרת (אותו מפתח NEXT_PUBLIC כמו ב־Clerk):
#   docker compose --env-file .env.prod -f docker-compose.prod.yml build --no-cache && docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
APP_IMAGE=parent-guide:latest

# למונגו בתוך קומפוז (ברירת מחדל)
MONGODB_URI=mongodb://mongo:27017/parent-guide

# Clerk (חובה לריצת האתר)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# כתובת האתר כפי שנראית מהמשתמש (לייצור redirects וקישורים)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# תמונות / Cloudinary (אם בשימוש)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# מייל (אופציונלי)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=
NEWSLETTER_BRAND_NAME=
